# Railway Postgres connection string (Railway provides this automatically as
# DATABASE_URL when you attach a Postgres service). For local dev, point it at
# your own Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/phoenix

# Secret used to sign our own JWTs. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-secret

# Phoenix AI (RAG) — get from platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
